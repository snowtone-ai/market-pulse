# market-pulse — .env.example
# 各キーを取得後、.env.local にコピーして値を記入する（このファイルは編集しない）
# .env.local は .gitignore 対象（絶対にコミットしない）

# ============================================================
# Gemini API（Google AI Studio）
# 取得先: https://aistudio.google.com/apikey
# 使用モデル: gemini-2.5-flash（gemini-2.0-flashは廃止済み・使用禁止）
# 無料枠: 10 RPM / 250 RPD / 1,000,000 TPM
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Finnhub API（ニュース・経済指標カレンダー）
# 取得先: https://finnhub.io → Sign Up → Dashboard → API Key
# 無料枠: 60 API calls/min、リアルタイム株価・ニュース・カレンダー利用可
# ============================================================
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================================
# GitHub Actions では上記を GitHub Secrets に設定する
# リポジトリ → Settings → Secrets and variables → Actions → New repository secret
# シークレット名は上記のキー名と完全一致させること（例: GEMINI_API_KEY）
# ============================================================

# ============================================================
# ローカル開発用設定（GitHub Actions では不要）
# ============================================================
# レポート出力先（デフォルト: docs/reports/）
OUTPUT_DIR=docs/reports

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# ローカルテスト用: 実際にGit pushしない（true=プッシュしない）
DRY_RUN=false
